#!/usr/bin/env python3

import time
import os
import subprocess
import requests
import datetime
from udp_flood_optimized import udp_flood

# Function that loops for exactly 1 minute (placeholder, does nothing)
def loop_function(attack_time, attack_function=None):
    func = globals().get(attack_function)
    if callable(func):
        print(f"Running attack function '{attack_function}' for {attack_time} seconds...")
        params = {"duration": attack_time}
        func(**params)
    else:
        print(f"Attack function '{attack_function}' not found. Sleeping for {attack_time} seconds.")
        time.sleep(attack_time)

def main():
    # Reset the simulation
    print("Resetting GCS logs and restarting MAVProxy...")
    requests.post("http://localhost:8000/reset")
    remote_cmd = (
        #"pkill -9 -f mavproxy.py || true; "
        #"rm -f /home/user/Documents/mavproxy/*.tlog*; " # removes .tlog and .tlog.raw file
        "/usr/bin/python3 /usr/local/bin/mavproxy.py --master=udp:0.0.0.0:14550 --logfile=/home/user/Documents/mavproxy/telemetry.tlog"
  
    )

    test1 = (
        "pkill -9 -f mavproxy.py || true;"
    )

    test2 = (
        "rm -f /home/user/Documents/mavproxy/*.tlog*; "
    )

    test3 = (
        "/usr/bin/python3 /usr/local/bin/mavproxy.py --master=udp:0.0.0.0:14550 --logfile=/home/user/Documents/mavproxy/telemetry.tlog"
    )

    subprocess.run([
        "docker", "exec", "-dt", 
        "ground-control-station-lite", 
        "sh", "-c", test1
    ])
    time.sleep(1)

    subprocess.run([
        "docker", "exec", "-dt", 
        "ground-control-station-lite", 
        "sh", "-c", test2
    ])
    time.sleep(1)

    subprocess.run([
        "docker", "exec", "-dt", 
        "ground-control-station-lite", 
        "sh", "-c", test3
    ])
    time.sleep(1)


    # Start stage 1
    print("Starting stage 1...")
    requests.post("http://localhost:8000/stage1")
    time.sleep(1)

    # Start stage 2
    print("Starting stage 2...")
    requests.post("http://localhost:8000/stage2")
    time.sleep(1)

    # Start stage 3
    print("Starting stage 3...")
    requests.post("http://localhost:8000/stage3")
    time.sleep(1)

    flight_time = 10
    print(f"Flying normally for {flight_time} seconds before attack...")
    time.sleep(flight_time)

    attack_function = "udp_flood"
    attack_time = 20
    print(f"Running attack function for {attack_time} seconds...")
    loop_function(attack_time, attack_function)
    

    print(f"Flying normally for another {flight_time} seconds after attack...")
    time.sleep(flight_time)

    # Create timestamped log directory
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    log_dir = f"./logs_{timestamp}"
    print(f"Saving logs to {log_dir}")

    # Download flight logs from flight controller
    print("Downloading flight logs...")
    flight_logs_dir = os.path.join(f"/home/wiktor/Desktop/Damn-Vulnerable-Drone/logs/{log_dir}/flashlogs")
    os.makedirs(flight_logs_dir, exist_ok=True)
    subprocess.run(["docker", "cp", "flight-controller-lite:/ardupilot/logs/.", flight_logs_dir])

    # Download tlogs from GCS
    print("Downloading tlogs...")
    tlogs_dir = os.path.join(f"/home/wiktor/Desktop/Damn-Vulnerable-Drone/logs/{log_dir}/tlogs")
    os.makedirs(tlogs_dir, exist_ok=True)
    subprocess.run(["docker", "cp", "ground-control-station-lite:/home/user/Documents/mavproxy/telemetry.tlog", tlogs_dir])
    print("Done.")

if __name__ == "__main__":
    main()
