import subprocess
import csv
import time
import sys
import json
import re

# --- CONFIGURATION ---
CONTAINER_NAME = "ground-control-station-lite"
OUTPUT_FILE = "./logs/docker-stats-logs.csv"
# ---------------------

def wait_for_container(name):
    """Polls docker until the specified container is found and running."""
    print(f"Waiting for container '{name}' to start...")
    while True:
        cmd = ["docker", "ps", "--filter", f"name={name}", "--filter", "status=running", "--format", "{{.Names}}"]
        result = subprocess.run(cmd, capture_output=True, text=True)
        
        if name in result.stdout:
            print(f"\n[+] Container '{name}' detected! Starting data stream...")
            return True

        sys.stdout.write(".")
        sys.stdout.flush()
        time.sleep(1)

def parse_to_mb(value_str):
    """Converts Docker unit strings (MiB, GiB, kB, B) to a float in MB."""
    if not value_str or value_str == '--': return 0.0
    # Remove units and find the number
    num = float(re.findall(r"[-+]?\d*\.\d+|\d+", value_str)[0])
    unit = value_str.lower()
    
    if 'g' in unit: return num * 1024
    if 'k' in unit: return num / 1024
    if 'b' in unit and 'k' not in unit and 'm' not in unit: return num / (1024 * 1024)
    return num # Default is MB/MiB

def stream_docker_stats():
    print(f"Monitoring {CONTAINER_NAME}... Logging all columns once per second.")
    
    last_logged_time = None
    
    # Define all columns available in docker stats
    fieldnames = [
        'timestamp', 'cpu_percent', 'mem_usage_mb', 'mem_limit_mb', 
        'mem_percent', 'net_input_mb', 'net_output_mb', 
        'block_input_mb', 'block_output_mb', 'pids'
    ]

    with open(OUTPUT_FILE, 'a', newline='') as csvfile:
        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
        if csvfile.tell() == 0:
            writer.writeheader()

        # Expanded format string to catch Block I/O and full Mem details
        format_str = (
            '{"cpu":"{{.CPUPerc}}","mem":"{{.MemUsage}}","m_perc":"{{.MemPerc}}",'
            '"net":"{{.NetIO}}","block":"{{.BlockIO}}","pids":"{{.PIDs}}"}'
        )

        cmd = ["docker", "stats", CONTAINER_NAME, "--format", format_str]
        process = subprocess.Popen(cmd, stdout=subprocess.PIPE, text=True)

        try:
            for line in iter(process.stdout.readline, ''):
                current_time = time.strftime("%Y-%m-%d %H:%M:%S")
                
                # Throttle to 1 entry per second
                if current_time == last_logged_time:
                    continue

                try:
                    start = line.find('{')
                    end = line.rfind('}') + 1
                    if start == -1 or end == 0: continue
                    stats = json.loads(line[start:end])
                except json.JSONDecodeError:
                    continue
                
                # Parsing Logic
                mem_used_raw, mem_limit_raw = stats['mem'].split(' / ')
                net_in_raw, net_out_raw = stats['net'].split(' / ')
                block_in_raw, block_out_raw = stats['block'].split(' / ')

                data = {
                    'timestamp': current_time,
                    'cpu_percent': float(stats['cpu'].replace('%', '').strip()),
                    'mem_usage_mb': parse_to_mb(mem_used_raw),
                    'mem_limit_mb': parse_to_mb(mem_limit_raw),
                    'mem_percent': float(stats['m_perc'].replace('%', '').strip()),
                    'net_input_mb': parse_to_mb(net_in_raw),
                    'net_output_mb': parse_to_mb(net_out_raw),
                    'block_input_mb': parse_to_mb(block_in_raw),
                    'block_output_mb': parse_to_mb(block_out_raw),
                    'pids': int(stats['pids']) if stats['pids'] != '--' else 0
                }

                writer.writerow(data)
                csvfile.flush()
                
                last_logged_time = current_time
                print(f"[{current_time}] CPU: {data['cpu_percent']}% | NetIn: {data['net_input_mb']:.2f}MB")

        except KeyboardInterrupt:
            process.terminate()
            print("\nLogging stopped.")

if __name__ == "__main__":
    target = sys.argv[1] if len(sys.argv) > 1 else CONTAINER_NAME
    # 1. Wait until container is alive
    if wait_for_container(target):
        # 2. Start streaming
        stream_docker_stats()